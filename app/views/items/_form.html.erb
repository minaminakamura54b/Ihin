<%= form_with(model: item, data: { controller: "item-form" }) do |f| %>
  <% if item.errors.any? %>
    <div class="error-messages">
      <h4><%= item.errors.count %>件のエラーがあります</h4>
      <ul>
        <% item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :images, "遺品の写真（最大5枚）", class: "form-label" %>
    <div class="upload-area" data-item-form-target="uploadArea" data-action="dragover->item-form#dragOver drop->item-form#drop">
      <% if item.images.attached? %>
        <div class="upload-preview" data-item-form-target="preview">
          <div class="preview-grid" data-item-form-target="previewGrid">
            <% item.images.each do |img| %>
              <%= image_tag img.variant(resize_to_fill: [200, 200]), class: "preview-thumb" %>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="upload-placeholder" data-item-form-target="placeholder">
          <i class="fas fa-camera upload-icon"></i>
          <p>タップして写真を選択</p>
          <p class="upload-hint">複数枚選択可（最大5枚）・ドラッグ&ドロップも可</p>
        </div>
        <div class="upload-preview hidden" data-item-form-target="preview">
          <div class="preview-grid" data-item-form-target="previewGrid"></div>
        </div>
      <% end %>
      <%= f.file_field :images, accept: "image/*", multiple: true,
          class: "upload-input",
          data: { action: "change->item-form#preview", item_form_target: "fileInput" } %>
    </div>
    <p class="form-hint">複数の角度から撮影すると査定精度が上がります</p>
  </div>

  <div class="form-group">
    <%= f.label :name, "品物の名前（任意）", class: "form-label" %>
    <%= f.text_field :name, class: "form-input", placeholder: "例：食器セット、着物、カメラなど" %>
    <p class="form-hint">写真だけでもAIが自動で判別します</p>
  </div>

  <div class="form-group">
    <%= f.label :memo, "メモ（任意）", class: "form-label" %>
    <%= f.text_area :memo, class: "form-input form-textarea", rows: 3,
        placeholder: "気になることや思い出などをメモしておけます" %>
  </div>

  <div class="form-actions">
    <%= f.submit item.new_record? ? "登録してAI査定する" : "更新する",
        class: "btn btn-primary btn-full", data: { disable_with: "処理中..." } %>
    <%= link_to "キャンセル", items_path, class: "btn btn-ghost btn-full" %>
  </div>
<% end %>
