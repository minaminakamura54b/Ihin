<% content_for :title, "#{@memory.display_title} | 遺品AI査定" %>

<div class="page-container page-narrow">
  <div class="breadcrumb">
    <%= link_to "デジタル記念館", memories_path %> &rsaquo; <%= @memory.display_title %>
  </div>

  <div class="memory-detail">
    <%# タイトル %>
    <h1 style="font-size: 22px; color: var(--navy); margin-bottom: 16px;"><%= @memory.display_title %></h1>

    <%# 写真 %>
    <% if @memory.photo.attached? %>
      <%= image_tag @memory.photo.variant(resize_to_limit: [700, 600]), class: "memory-detail-photo" %>
    <% end %>

    <%# 関連遺品 %>
    <% if @memory.item %>
      <div class="memory-item-link">
        <i class="fas fa-box"></i>
        関連する遺品：<%= link_to @memory.item.name || "名前未設定", item_path(@memory.item) %>
      </div>
    <% end %>

    <%# エピソード %>
    <% text = @memory.description.presence || @memory.comment.presence %>
    <% if text.present? %>
      <div class="memory-detail-comment">
        <p style="white-space: pre-wrap;"><%= text %></p>
      </div>
    <% end %>

    <%# AI追悼文 %>
    <% if @memory.ai_summary.present? %>
      <div class="memorial-ai-summary">
        <p style="font-size: 12px; color: var(--text-sub); margin-bottom: 8px;"><i class="fas fa-robot"></i> AIが生成した追悼文</p>
        <%= @memory.ai_summary %>
      </div>
    <% end %>

    <p class="memory-detail-date"><%= @memory.created_at.strftime("%Y年%m月%d日") %></p>

    <%# アクションボタン群 %>
    <div class="form-actions" style="flex-wrap: wrap; gap: 10px;">
      <%# AI追悼文を生成 %>
      <%= button_to "AIで追悼文を生成",
            generate_ai_summary_memory_path(@memory),
            method: :post,
            class: "btn btn-outline",
            data: { turbo_confirm: "AIが追悼文を生成します。既存の追悼文は上書きされます。" } %>

      <%# 家族共有セクション %>
      <div id="memory_share_<%= @memory.id %>"
           data-controller="share-memory"
           data-share-memory-url-value="<%= shared_memory_url(@memory.share_token) %>"
           data-share-memory-toggle-path-value="<%= toggle_share_memory_path(@memory) %>"
           data-share-memory-shared-value="<%= @memory.shared? %>">

        <% if @memory.shared? %>
          <%# 共有中：URL表示とコピーボタン %>
          <div class="share-active-box" data-share-memory-target="activeBox">
            <p class="share-active-label">
              <i class="fas fa-share-alt"></i> 共有URLが有効です
            </p>
            <div class="share-url-row">
              <input type="text" class="share-url-input" readonly
                     value="<%= shared_memory_url(@memory.share_token) %>"
                     data-share-memory-target="urlInput">
              <button type="button" class="btn btn-primary btn-sm"
                      data-action="share-memory#copyUrl">
                <i class="fas fa-copy"></i>
                <span data-share-memory-target="copyLabel">URLをコピー</span>
              </button>
            </div>
            <button type="button" class="btn btn-ghost btn-sm"
                    style="margin-top: 8px;"
                    data-action="share-memory#stopShare">
              共有を停止する
            </button>
          </div>
          <%# 共有停止モーダル %>
          <div class="modal-overlay hidden" data-share-memory-target="stopModal">
            <div class="modal-box">
              <div class="modal-icon">🔒</div>
              <h2>共有を停止しますか？</h2>
              <p>共有を停止すると、共有URLにアクセスできなくなります。</p>
              <div class="modal-actions">
                <button type="button" class="btn btn-danger"
                        data-action="share-memory#confirmStop">停止する</button>
                <button type="button" class="btn btn-ghost"
                        data-action="share-memory#closeModal">キャンセル</button>
              </div>
            </div>
          </div>

        <% else %>
          <%# 未共有：共有ボタン %>
          <button type="button" class="btn btn-outline"
                  data-share-memory-target="shareBtn"
                  data-action="share-memory#openShareModal">
            <i class="fas fa-share-alt"></i> 家族に共有する
          </button>
          <%# 共有開始確認モーダル %>
          <div class="modal-overlay hidden" data-share-memory-target="shareModal">
            <div class="modal-box">
              <div class="modal-icon">🔗</div>
              <h2>追悼ページを共有しますか？</h2>
              <p>このページは<strong>URLを知っている人なら誰でも</strong>見られるようになります。よろしいですか？</p>
              <div class="modal-actions">
                <button type="button" class="btn btn-primary"
                        data-action="share-memory#confirmShare">共有する</button>
                <button type="button" class="btn btn-ghost"
                        data-action="share-memory#closeModal">キャンセル</button>
              </div>
            </div>
          </div>
        <% end %>

        <%# フォーム（Stimulusから送信） %>
        <%= form_with url: toggle_share_memory_path(@memory), method: :patch,
              data: { share_memory_target: "form" }, style: "display: none;" do |f| %>
        <% end %>
      </div>
    </div>

    <div class="form-actions" style="margin-top: 8px;">
      <%= link_to "編集", edit_memory_path(@memory), class: "btn btn-ghost" %>
      <%= button_to "削除", memory_path(@memory), method: :delete,
            class: "btn btn-danger",
            data: { turbo_confirm: "削除しますか？" } %>
    </div>
  </div>
</div>
