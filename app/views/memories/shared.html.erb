<% content_for :title, "#{@memory.display_title} | 追悼ページ" %>

<div class="memorial-page">

  <%# ヘッダー：名前と日付 %>
  <div class="memorial-header">
    <div class="memorial-header-icon">
      <i class="fas fa-heart"></i>
    </div>
    <h1 class="memorial-name"><%= @memory.display_title %></h1>
    <p class="memorial-date"><%= @memory.created_at.strftime("%Y年%m月%d日") %></p>
  </div>

  <%# 写真 %>
  <% if @memory.photo.attached? %>
    <div class="memorial-photo-wrap">
      <%= image_tag @memory.photo.variant(resize_to_limit: [800, 700]),
            class: "memorial-photo",
            alt: @memory.display_title %>
    </div>
  <% end %>

  <%# AI追悼文 %>
  <% if @memory.ai_summary.present? %>
    <div class="memorial-tribute">
      <div class="memorial-tribute-icon">
        <i class="fas fa-feather-alt"></i>
      </div>
      <p class="memorial-tribute-text"><%= @memory.ai_summary %></p>
    </div>
  <% end %>

  <%# エピソード %>
  <% text = @memory.description.presence || @memory.comment.presence %>
  <% if text.present? %>
    <div class="memorial-episode">
      <h2 class="memorial-episode-title">
        <i class="fas fa-book-open"></i> 思い出のエピソード
      </h2>
      <p class="memorial-episode-text"><%= text %></p>
    </div>
  <% end %>

  <%# フッター %>
  <div class="memorial-footer">
    <div class="memorial-footer-divider"></div>
    <p class="memorial-footer-caption">
      <i class="fas fa-heart" style="color: var(--teal);"></i>
      大切な思い出を、いつまでも。
    </p>
    <%= link_to "無料で追悼ページを作る", new_user_registration_path,
          class: "btn btn-outline memorial-footer-btn" %>
  </div>

</div>
