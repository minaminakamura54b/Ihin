<%# 業者への新規問い合わせ通知メール %>
<p><%= @business.user.name %> 様</p>

<p>
  <strong style="color: #2c4f7c;"><%= @sender.name %></strong> 様から
  新しいお問い合わせが届きました。
</p>

<%# 問い合わせ内容 %>
<table style="border-collapse:collapse; margin: 20px 0; width: 100%; max-width: 540px;">
  <tr>
    <td style="padding: 8px 16px 8px 0; color: #5a5a5a; white-space: nowrap; vertical-align: top;">お名前</td>
    <td style="padding: 8px 0;"><strong><%= @sender.name %></strong></td>
  </tr>
  <tr style="background: #f9f7f4;">
    <td style="padding: 8px 16px 8px 8px; color: #5a5a5a; white-space: nowrap; vertical-align: top;">連絡先</td>
    <td style="padding: 8px 0;">
      <strong style="color: #2a7f6f;"><%= @inquiry.contact_info %></strong>
      <span style="color: #999; font-size: 12px;">
        （<%= @inquiry.email? ? "メールアドレス" : "電話番号" %>）
      </span>
    </td>
  </tr>
  <tr>
    <td style="padding: 8px 16px 8px 0; color: #5a5a5a; white-space: nowrap; vertical-align: top;">問い合わせ日時</td>
    <td style="padding: 8px 0;"><%= @inquiry.created_at.strftime("%Y年%m月%d日 %H:%M") %></td>
  </tr>
</table>

<%# メッセージ本文 %>
<div style="background: #f5f0e8; border-left: 4px solid #7c6b5a; padding: 16px 20px; border-radius: 0 8px 8px 0; margin: 16px 0;">
  <p style="margin: 0; font-size: 13px; color: #5a5a5a; margin-bottom: 8px;">メッセージ</p>
  <p style="margin: 0; line-height: 1.8; white-space: pre-wrap;"><%= @inquiry.message %></p>
</div>

<p style="color: #2c4f7c; font-weight: bold;">
  以降は直接ご連絡ください。
</p>

<p>
  <a href="https://<%= ENV.fetch("APP_HOST", "ihin-app.jp") %>/users/sign_in"
     style="display:inline-block; background:#2c4f7c; color:white; padding:10px 24px; border-radius:8px; text-decoration:none; font-weight:bold;">
    ダッシュボードで確認する
  </a>
</p>

<p style="margin-top: 32px; color: #999; font-size: 12px;">
  このメールは Ihin（https://<%= ENV.fetch("APP_HOST", "ihin-app.jp") %>）から自動送信されています。
</p>
