<% content_for :title, "ユーザー管理 | 管理画面" %>

<div class="page-container">
  <div class="page-header">
    <h1>ユーザー管理</h1>
    <p class="page-subtitle">全 <%= @users.total_count %> 名</p>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>名前</th>
        <th>メール</th>
        <th>ロール</th>
        <th>登録日</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.id %></td>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td>
            <span class="badge <%= user.admin? ? 'badge-red' : user.business? ? 'badge-blue' : 'badge-gray' %>">
              <%= user.admin? ? "管理者" : user.business? ? "業者" : "遺族" %>
            </span>
          </td>
          <td><%= user.created_at.strftime("%Y/%m/%d") %></td>
          <td class="admin-table-actions">
            <%= link_to "詳細", admin_user_path(user), class: "btn btn-sm btn-outline" %>
            <%= link_to "編集", edit_admin_user_path(user), class: "btn btn-sm btn-ghost" %>
            <%= button_to "削除", admin_user_path(user), method: :delete,
                class: "btn btn-sm btn-danger",
                data: { turbo_confirm: "#{user.name}を削除しますか？" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="pagination"><%= paginate @users %></div>
</div>

<style>
.admin-table { width: 100%; border-collapse: collapse; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
.admin-table th { background: var(--color-warm-100); padding: 12px 16px; text-align: left; font-size: 0.85rem; color: var(--color-text-light); }
.admin-table td { padding: 12px 16px; border-top: 1px solid var(--color-warm-100); font-size: 0.9rem; }
.admin-table-actions { display: flex; gap: 6px; }
</style>
