<% content_for :title, "業者管理 | 管理画面" %>

<div class="page-container">
  <div class="page-header">
    <h1>業者管理</h1>
    <p class="page-subtitle">全 <%= @businesses.total_count %> 社
      <% if @pending_count > 0 %>
        <span class="badge badge-warning" style="margin-left: 8px;"><%= @pending_count %>件 審査待ち</span>
      <% end %>
    </p>
  </div>

  <%# ステータスフィルター %>
  <div class="filter-tabs" style="margin-bottom: 20px;">
    <%= link_to "すべて", admin_businesses_path,
          class: "filter-tab #{params[:status].blank? ? 'active' : ''}" %>
    <%= link_to "審査待ち", admin_businesses_path(status: "pending"),
          class: "filter-tab #{params[:status] == 'pending' ? 'active' : ''}" %>
    <%= link_to "承認済み", admin_businesses_path(status: "approved"),
          class: "filter-tab #{params[:status] == 'approved' ? 'active' : ''}" %>
    <%= link_to "却下", admin_businesses_path(status: "rejected"),
          class: "filter-tab #{params[:status] == 'rejected' ? 'active' : ''}" %>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>会社名</th>
        <th>業種</th>
        <th>エリア</th>
        <th>プラン</th>
        <th>審査</th>
        <th>掲載</th>
        <th>登録日</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @businesses.each do |business| %>
        <tr>
          <td><%= business.id %></td>
          <td><%= business.name %></td>
          <td><%= business.category_label %></td>
          <td><%= business.area.presence || "—" %></td>
          <td><%= business.plan %></td>
          <td>
            <% status_class = { "pending" => "badge-warning", "approved" => "badge-green", "rejected" => "badge-red" }[business.approval_status] %>
            <span class="badge <%= status_class %>"><%= business.approval_status_label %></span>
          </td>
          <td>
            <span class="badge <%= business.active? ? 'badge-green' : 'badge-gray' %>">
              <%= business.active? ? "公開" : "非公開" %>
            </span>
          </td>
          <td><%= business.created_at.strftime("%Y/%m/%d") %></td>
          <td class="admin-table-actions">
            <%= link_to "詳細", admin_business_path(business), class: "btn btn-sm btn-outline" %>
            <%= link_to "編集", edit_admin_business_path(business), class: "btn btn-sm btn-ghost" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="pagination"><%= paginate @businesses %></div>
</div>

<style>
.admin-table { width: 100%; border-collapse: collapse; background: white; border-radius: var(--radius); overflow: hidden; }
.admin-table th { background: var(--teal-light); padding: 10px 14px; text-align: left; font-size: 12px; color: var(--text-sub); }
.admin-table td { padding: 10px 14px; border-top: 0.5px solid var(--border); font-size: 13px; }
.admin-table-actions { display: flex; gap: 6px; }
.filter-tabs { display: flex; gap: 8px; flex-wrap: wrap; }
.filter-tab { padding: 6px 14px; border-radius: 999px; font-size: 13px; color: var(--text-sub); border: 0.5px solid var(--border); transition: opacity 0.2s; background: white; }
.filter-tab:hover { opacity: 0.75; }
.filter-tab.active { background: var(--navy); color: white; border-color: var(--navy); }
</style>
