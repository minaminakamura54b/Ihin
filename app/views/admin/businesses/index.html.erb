<% content_for :title, "業者管理 | 管理画面" %>

<div class="page-container">
  <div class="page-header">
    <h1>業者管理</h1>
    <p class="page-subtitle">全 <%= @businesses.total_count %> 社</p>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>業者名</th>
        <th>業種</th>
        <th>エリア</th>
        <th>プラン</th>
        <th>状態</th>
        <th>登録日</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @businesses.each do |business| %>
        <tr>
          <td><%= business.id %></td>
          <td><%= business.name %></td>
          <td><%= business.category_label %></td>
          <td><%= business.area %></td>
          <td><%= business.plan %></td>
          <td>
            <span class="badge <%= business.active? ? 'badge-green' : 'badge-gray' %>">
              <%= business.active? ? "有効" : "無効" %>
            </span>
          </td>
          <td><%= business.created_at.strftime("%Y/%m/%d") %></td>
          <td class="admin-table-actions">
            <%= link_to "詳細", admin_business_path(business), class: "btn btn-sm btn-outline" %>
            <%= link_to "編集", edit_admin_business_path(business), class: "btn btn-sm btn-ghost" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="pagination"><%= paginate @businesses %></div>
</div>

<style>
.admin-table { width: 100%; border-collapse: collapse; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
.admin-table th { background: var(--color-warm-100); padding: 12px 16px; text-align: left; font-size: 0.85rem; color: var(--color-text-light); }
.admin-table td { padding: 12px 16px; border-top: 1px solid var(--color-warm-100); font-size: 0.9rem; }
.admin-table-actions { display: flex; gap: 6px; }
</style>
