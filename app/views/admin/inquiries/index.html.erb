<% content_for :title, "問い合わせ管理 | 管理画面" %>

<div class="page-container">
  <div class="page-header">
    <h1>問い合わせ管理</h1>
    <p class="page-subtitle">全 <%= @inquiries.total_count %> 件</p>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>送信日時</th>
        <th>遺族</th>
        <th>業者</th>
        <th>ステータス</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @inquiries.each do |inquiry| %>
        <tr>
          <td><%= inquiry.id %></td>
          <td><%= inquiry.created_at.strftime("%Y/%m/%d %H:%M") %></td>
          <td><%= inquiry.user.name %></td>
          <td><%= inquiry.business.name %></td>
          <td>
            <span class="badge <%= inquiry.pending? ? 'badge-yellow' : inquiry.contacted? ? 'badge-blue' : 'badge-gray' %>">
              <%= inquiry.pending? ? "未対応" : inquiry.contacted? ? "対応中" : "完了" %>
            </span>
          </td>
          <td>
            <%= link_to "詳細", admin_inquiry_path(inquiry), class: "btn btn-sm btn-outline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="pagination"><%= paginate @inquiries %></div>
</div>

<style>
.admin-table { width: 100%; border-collapse: collapse; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
.admin-table th { background: var(--color-warm-100); padding: 12px 16px; text-align: left; font-size: 0.85rem; color: var(--color-text-light); }
.admin-table td { padding: 12px 16px; border-top: 1px solid var(--color-warm-100); font-size: 0.9rem; }
</style>
