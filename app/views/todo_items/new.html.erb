<% content_for :title, "タスクを追加 | いひん" %>

<div class="page-container page-narrow">
  <div class="page-header">
    <h1>タスクを追加する</h1>
  </div>

  <%= form_with(model: @todo_item) do |f| %>
    <% if @todo_item.errors.any? %>
      <div class="error-messages">
        <ul>
          <% @todo_item.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :title, "やること", class: "form-label" %>
      <%= f.text_field :title, class: "form-input", placeholder: "例：銀行口座の解約" %>
    </div>

    <div class="form-group">
      <%= f.label :category, "カテゴリ", class: "form-label" %>
      <%= f.select :category, [["急ぎ", "urgent"], ["通常", "normal"], ["デジタル遺品", "digital"]],
          {}, class: "form-select" %>
    </div>

    <div class="form-group">
      <%= f.label :priority, "優先度", class: "form-label" %>
      <%= f.select :priority, [["高", 1], ["中", 2], ["低", 3]], {}, class: "form-select" %>
    </div>

    <div class="form-actions">
      <%= f.submit "追加する", class: "btn btn-primary btn-full" %>
      <%= link_to "キャンセル", todo_items_path, class: "btn btn-ghost btn-full" %>
    </div>
  <% end %>
</div>
