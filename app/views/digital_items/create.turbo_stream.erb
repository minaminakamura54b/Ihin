<%# 新しいアイテムをリストの先頭に追加 %>
<%= turbo_stream.prepend "digital_items_list" do %>
  <%= render "digital_item", item: @digital_item %>
<% end %>

<%# プログレスバーを更新 %>
<% total     = current_user.digital_items.count %>
<% completed = current_user.digital_items.completed.count %>
<% pct       = total > 0 ? (completed.to_f / total * 100).round : 0 %>
<%= turbo_stream.replace "digital_progress" do %>
  <div class="digital-progress-card" id="digital_progress">
    <div class="digital-progress-header">
      <span class="progress-label"><%= completed %>/<%= total %>件 完了</span>
      <span class="progress-pct"><%= pct %>%</span>
    </div>
    <div class="progress-bar-track">
      <div class="progress-bar-fill" style="width: <%= pct %>%"></div>
    </div>
    <% if pct == 100 && total > 0 %>
      <p class="progress-complete-msg"><i class="fas fa-check-circle"></i> すべての整理が完了しました！</p>
    <% end %>
  </div>
<% end %>
