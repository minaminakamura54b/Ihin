<% content_for :title, "業者登録 | 遺品AI査定" %>

<div class="page-container page-narrow">
  <div class="page-header">
    <h1>業者情報を登録する</h1>
    <p class="page-subtitle">遺族に向けてサービスを紹介しましょう</p>
  </div>

  <%= form_with model: @business do |f| %>
    <% if @business.errors.any? %>
      <div class="error-messages">
        <ul>
          <% @business.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :name, "業者名", class: "form-label required" %>
      <%= f.text_field :name, class: "form-input", placeholder: "例：○○遺品整理センター" %>
    </div>

    <div class="form-group">
      <%= f.label :category, "業種", class: "form-label required" %>
      <%= f.select :category, [["遺品整理業者", "estate_clearance"],
          ["買取業者", "buyback"], ["司法書士", "judicial_scrivener"]],
          {}, class: "form-select" %>
    </div>

    <%= render "businesses/service_prefectures_input", f: f, business: @business %>

    <div class="form-group">
      <%= f.label :description, "事業者の説明", class: "form-label" %>
      <%= f.text_area :description, class: "form-input form-textarea", rows: 4,
          placeholder: "サービス内容や強みをご記入ください" %>
    </div>

    <div class="form-group">
      <%= f.label :phone, "電話番号", class: "form-label" %>
      <%= f.telephone_field :phone, class: "form-input", placeholder: "03-0000-0000" %>
    </div>

    <div class="form-group">
      <%= f.label :website, "ウェブサイト", class: "form-label" %>
      <%= f.url_field :website, class: "form-input", placeholder: "https://" %>
    </div>

    <div class="form-group">
      <%= f.label :plan, "プラン", class: "form-label required" %>
      <div class="plan-selector">
        <label class="plan-option">
          <%= f.radio_button :plan, "basic" %>
          <div class="plan-option-content">
            <strong>ベーシック</strong>
            <span>月額3万円</span>
          </div>
        </label>
        <label class="plan-option plan-option-featured">
          <%= f.radio_button :plan, "standard" %>
          <div class="plan-option-content">
            <strong>スタンダード</strong>
            <span>月額4万円</span>
            <small>おすすめ</small>
          </div>
        </label>
        <label class="plan-option">
          <%= f.radio_button :plan, "premium" %>
          <div class="plan-option-content">
            <strong>プレミアム</strong>
            <span>月額5万円</span>
          </div>
        </label>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit "登録する", class: "btn btn-primary btn-full" %>
      <%= link_to "キャンセル", root_path, class: "btn btn-ghost btn-full" %>
    </div>
  <% end %>
</div>
