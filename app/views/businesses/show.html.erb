<% content_for :title, "#{@business.name}｜Ihin" %>
<% content_for :description, "#{@business.name}（#{@business.area.presence || '全国対応'}）の業者情報です。#{@business.category_label}として、遺品整理・買取のご相談を受け付けています。" %>

<% content_for :json_ld do %>
  <% ld = {
    "@context"    => "https://schema.org",
    "@type"       => "LocalBusiness",
    "name"        => @business.name,
    "description" => @business.description.presence || "#{@business.category_label}として遺品整理・買取のサポートをいたします。",
    "url"         => business_url(@business)
  }
  ld["address"]   = { "@type" => "PostalAddress", "addressLocality" => @business.area, "addressCountry" => "JP" } if @business.area.present?
  ld["telephone"] = @business.phone if @business.phone.present?
  ld["sameAs"]    = @business.website if @business.website.present?
  %>
  <script type="application/ld+json">
    <%= ld.to_json.html_safe %>
  </script>

  <script type="application/ld+json">
    <%= {
      "@context" => "https://schema.org",
      "@type"    => "BreadcrumbList",
      "itemListElement" => [
        { "@type" => "ListItem", "position" => 1, "name" => "トップ",     "item" => root_url },
        { "@type" => "ListItem", "position" => 2, "name" => "業者を探す", "item" => businesses_url },
        { "@type" => "ListItem", "position" => 3, "name" => @business.name, "item" => business_url(@business) }
      ]
    }.to_json.html_safe %>
  </script>
<% end %>

<div class="page-container">
  <div class="breadcrumb">
    <%= link_to "業者を探す", businesses_path %> &rsaquo; <%= @business.name %>
  </div>

  <div class="business-detail">
    <div class="business-detail-header">
      <div>
        <span class="business-category-badge"><%= @business.category_label %></span>
        <h1><%= @business.name %></h1>
        <% if @business.service_prefectures.any? %>
          <p class="business-area">
            <i class="fas fa-map-marker-alt"></i>
            <%= @business.service_prefectures.join("・") %>
          </p>
        <% elsif @business.area.present? %>
          <p class="business-area"><i class="fas fa-map-marker-alt"></i> <%= @business.area %></p>
        <% end %>
      </div>
    </div>

    <div class="business-detail-body">
      <% if @business.description.present? %>
        <div class="business-section">
          <h2>事業者について</h2>
          <p><%= @business.description %></p>
        </div>
      <% end %>

      <div class="business-info-grid">
        <% if @business.phone.present? %>
          <div class="business-info-item">
            <span class="info-label"><i class="fas fa-phone"></i> 電話番号</span>
            <span><%= @business.phone %></span>
          </div>
        <% end %>
        <% if @business.website.present? %>
          <div class="business-info-item">
            <span class="info-label"><i class="fas fa-globe"></i> ウェブサイト</span>
            <a href="<%= @business.website %>" target="_blank" rel="noopener"><%= @business.website %></a>
          </div>
        <% end %>
      </div>
    </div>

    <%# id="inquiry" → 検索結果の「問い合わせる」リンクのアンカー先 %>
    <div class="inquiry-section" id="inquiry">
      <h2>問い合わせる</h2>
      <% if user_signed_in? %>
        <% if @already_inquired %>
          <%# 24時間以内に問い合わせ済みの場合 %>
          <div class="inquiry-already-sent">
            <i class="fas fa-check-circle"></i>
            この業者にはすでにお問い合わせいただいています。<br>
            <span class="inquiry-already-note">24時間経過後に再度ご連絡いただけます。</span>
          </div>
        <% else %>
          <p class="inquiry-note">無料で問い合わせができます。ご入力いただいた連絡先に業者から直接ご連絡します。</p>
          <%= link_to new_business_inquiry_path(@business),
                class: "btn btn-primary inquiry-cta-btn" do %>
            <i class="fas fa-envelope"></i> 問い合わせる
          <% end %>
        <% end %>
      <% else %>
        <p class="inquiry-note">問い合わせるには無料登録が必要です。</p>
        <%= link_to new_user_registration_path, class: "btn btn-primary" do %>
          <i class="fas fa-user-plus"></i> 無料登録して問い合わせる
        <% end %>
      <% end %>
    </div>
  </div>
</div>
